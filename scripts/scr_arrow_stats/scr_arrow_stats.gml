function scr_arrow_stats() {
	// Comportamiento
	shipLevel = 1;
	is_enemy = true;
	
	// // Defensa
	shipHealth = 2;
	shipDefense = 0.2;
	shipDodge = 5;
	
	// // Ataque
	shipAttack = 1;
	shipCritAttack = 1.2;
	shipCritChance = 5;
	
	// // Movimiento
	shipSpeed = 1;
	shipDirection = 0
	shipAngle = 0
	
	// // Efecto al Spawnear
	shipSpawnAlpha = 0;
	shipSpawnAlphaMax = 1;
	is_Spawned = false;
	image_alpha = 0;
}